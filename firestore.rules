rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User settings and theme prefs (userData/{uid} doc itself)
    match /userData/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Characters subcollection — must be matched explicitly;
      // the parent rule above does NOT cover subcollection paths.
      match /characters/{charId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Public-ish user display names / nicknames
    match /userProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Sign-in history and per-device presence
    match /auth_signins/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
